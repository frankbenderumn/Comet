#!/bin/bash
ROOTDIR=`git rev-parse --show-toplevel`
source ${ROOTDIR}/config/comet

if [[ "$1" == "get" ]]; then
    if [[ -d "${COMET}/source/pugixml-source" ]]; then
        echo -e "pugixml source already installed"
    else
        echo -e "${YEL}Installing pugixml...${CLR}"
        cd "${COMET}/source"
        wget https://github.com/zeux/pugixml/releases/download/v1.12/pugixml-1.12.tar.gz
        tar -xf pugixml-1.12.tar.gz
        mv pugixml-1.12 pugixml-source
        rm -f pugixml-1.12.tar.gz
    fi
elif [[ "$1" == "build" ]]; then
    :
    # cd ${COMET}
    # mkdir -p pugixml
    # cd pugixml-source
    # mkdir -p build
    # cd build
    # cmake .. -DCMAKE_INSTALL_PREFIX=${EXT_PATH}/pugixml -DBUILD_SHARED_LIBS=ON
    # make -j`nproc`
    # make install
elif [[ "$1" == "install" ]]; then
    if [[ -d "${COMET}/source/pugixml-source" ]]; then
        echo -e "pugixml source already installed"
    else
        # if [[ -d "${COMET}/pugixml-source" ]]; then
        #     cd ${EXT_PATH}
        #     cd pugixml-source
        #     mkdir -p build
        #     cd build
        #     cmake .. -DCMAKE_INSTALL_PREFIX=${EXT_PATH}/pugixml -DBUILD_SHARED_LIBS=ON
        #     make -j
        #     make install
        # else
        echo -e "${YEL}Installing pugixml...${CLR}"
        cd ${COMET}
        wget https://github.com/zeux/pugixml/releases/download/v1.12/pugixml-1.12.tar.gz
        tar -xf pugixml-1.12.tar.gz
        mv ${COMET}/pugixml-1.12 ${COMET}/pugixml-source
        rm -f ${COMET}/pugixml-1.12.tar.gz
        # mkdir -p ${COMET}/pugixml
        cd ${COMET}/pugixml-source
        mkdir -p cmake-build
        cd cmake-build
        cmake .. -DCMAKE_INSTALL_PREFIX=${COMET}/build/pugixml -DBUILD_SHARED_LIBS=ON
        make -j
        make install
        cd ../..
        sudo cp -r ./build/pugixml/include ./include/pugixml
        sudo cp -r ./build/pugixml/lib/* ./lib
        cd ./build/pugixml/lib
        sudo rm -rf cmake
        # fi
    fi
elif [[ "$1" == "uninstall" ]]; then
    :
    # cd "${EXT_PATH}"
    # rm -rf pugixml
    # rm -rf pugixml-source
else
    echo -e "${RED}Invalid argument for pugixml install${CLR}"
fi